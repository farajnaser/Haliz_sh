generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  role      String    @default("ADMIN")
  products  Product[]
}

model Partner {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  shares    ProductOwner[]
}

model ProductOwner {
  id         String  @id @default(cuid())
  productId  String
  amount     Float
  partnerId  String
  paidProfit Float   @default(0)
  partner    Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([partnerId])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  nameAr      String?
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id             String         @id @default(cuid())
  name           String
  nameAr         String?
  slug           String         @unique
  description    String?
  descriptionAr  String?
  retailPrice    Float
  wholesalePrice Float
  profit         Float          @default(0)
  stock          Int            @default(0)
  sku            String?        @unique
  barcode        String?
  featured       Boolean        @default(false)
  images         String[]       @default([])
  categoryId     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  status         String         @default("ACTIVE")
  createdById    String?
  salePrice      Float?
  orderItems     OrderItem[]
  category       Category?      @relation(fields: [categoryId], references: [id])
  createdBy      User?          @relation(fields: [createdById], references: [id])
  owners         ProductOwner[]

  @@index([categoryId])
  @@index([featured])
  @@index([status])
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerPhone String
  notes         String?
  total         Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  status        String      @default("PENDING")
  items         OrderItem[]
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  quantity       Int
  price          Float
  soldStatus     String  @default("PENDING")
  discountAmount Float   @default(0)
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Settings {
  id             String   @id @default(cuid())
  storeName      String   @default("HALIZ")
  storeNameAr    String   @default("هاليز")
  description    String?
  descriptionAr  String?
  logo           String?
  whatsappNumber String   @default("966500000000")
  instagram      String?
  twitter        String?
  facebook       String?
  address        String?
  addressAr      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tiktok         String?
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String   @default("OTHER") // MARKETING, SHIPPING, RENT, SALARIES, OTHER
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([date])
}
